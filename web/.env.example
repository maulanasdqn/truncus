# Point the dev proxy at a different Worker (e.g. a local `wrangler dev`).
# Defaults to https://truncus.stynx.app when unset. Used only by `vite dev`.
TRUNCUS_API_URL=https://truncus.stynx.app

# Only set this if you deploy the dashboard as static files and call a
# CORS-enabled Worker directly (this bypasses the dev proxy).
# VITE_API_URL=https://truncus.stynx.app
